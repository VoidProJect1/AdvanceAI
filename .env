# ─────────────────────────────────────────────────────────────────────────────
#  .env — Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=token

# Groq API Key (from console.groq.com)
GROQ_API_KEY=key

# Mistral AI API Key (from console.mistral.ai)
MISTRAL_API_KEY=api

# Your Telegram User ID (from @userinfobot) — leave empty to allow all users
ADMIN_IDS=5479881365

# Log level
LOG_LEVEL=INFO
